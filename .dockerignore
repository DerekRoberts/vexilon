# Exclude large cache directories from docker build context
hf_cache/

# Raw PDFs in the cache dir are large; exclude them.
# The pre-built index files (index.faiss, chunks.json) ARE included so the
# Containerfile can bake them into the image for a fast cold start.
pdf_cache/*.pdf

# Standard Python ignores
__pycache__/
*.pyc
.venv/
.pytest_cache/
.coverage
