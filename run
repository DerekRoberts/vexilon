#!/usr/bin/env bash
# High-integrity task runner for Agreement Navigator
set -euo pipefail

# Print help/usage instructions if an invalid command is passed
usage() {
    echo "📋 Agreement Navigator Task Runner"
    echo "Usage: ./run <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  dev       Boot the local development environment (Ollama + Chainlit app)"
    echo "  down      Tear down all active containers and prune volumes"
    echo "  build     Rebuild all Docker/Podman container images"
    echo "  test      Run local unit and streaming tests via pytest"
    echo "  test-all  Run full containerized integration and e2e test suite"
    echo ""
    exit 1
}

# Auto-detect container runtime
if command -v podman-compose >/dev/null 2>&1; then
    COMPOSE="podman compose"
elif command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    COMPOSE="docker compose"
else
    echo "❌ Error: Neither podman-compose nor docker-compose was detected on your PATH." >&2
    exit 1
fi

if [ $# -lt 1 ]; then
    usage
fi

CMD=$1
shift

case "$CMD" in
    dev)
        echo "🚀 Starting development environment using $COMPOSE..."
        $COMPOSE -f app/compose.yml up --build dev "$@"
        ;;
    down)
        echo "🧹 Tearing down dev environment..."
        $COMPOSE -f app/compose.yml down -v "$@"
        ;;
    build)
        echo "📦 Building container images..."
        $COMPOSE -f app/compose.yml build "$@"
        ;;
    test)
        echo "🧪 Running local unit and streaming tests..."
        cd app
        uv run pytest ../tests/deploy_integrity/ tests/test_rag_stream.py -v "$@"
        ;;
    test-all)
        echo "⚡ Running all containerized integration and E2E suites..."
        $COMPOSE -f app/compose.yml up --build test-everything "$@"
        ;;
    *)
        echo "❌ Error: Unknown command '$CMD'" >&2
        usage
        ;;
esac
